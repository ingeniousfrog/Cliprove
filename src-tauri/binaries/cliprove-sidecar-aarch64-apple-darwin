#!/usr/bin/env bash
set -euo pipefail

# Development stub for Tauri externalBin resolution.
# Release builds replace this file via scripts/build-sidecar.sh (PyInstaller).

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
PYTHON="$ROOT/sidecar/.venv/bin/python3"

if [[ ! -x "$PYTHON" ]]; then
  PYTHON="python3"
fi

exec "$PYTHON" "$ROOT/sidecar/app.py" "$@"
